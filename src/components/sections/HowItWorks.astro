---
import { HOW } from '../../site.config';
---

<section id="how" class="section">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="eyebrow">{HOW.eyebrow}</p>
      <h2 class="section-title">{HOW.heading}</h2>
    </div>

    <ol class="how__grid" role="list" data-reveal data-reveal-children>
      {
        HOW.steps.map((step, index) => (
          <li class="how__cell">
            <div class="card-spotlight how-card" style="--spotlight-color: var(--spot-accent)">
              <p class="how-card__num mono" aria-hidden="true">
                {String(index + 1).padStart(2, '0')}
              </p>
              <h3 class="how-card__title">{step.title}</h3>
              <p class="how-card__desc">{step.description}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <p class="how__closing">{HOW.closing}</p>
  </div>
</section>

<script>
  // Spotlight position tracking (the hover/focus reveal itself is pure CSS,
  // see SpotlightCard.css). Pointer listeners only fire while hovering, so
  // this costs nothing at load.
  document.querySelectorAll<HTMLElement>('.card-spotlight').forEach(card => {
    card.addEventListener('pointermove', e => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
      card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
    });
  });
</script>

<style>
  .how__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 40em) {
    .how__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 60em) {
    .how__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .how__cell :global(.how-card) {
    block-size: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .how-card__num {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-caption);
    letter-spacing: var(--letter-spacing-eyebrow);
  }

  .how-card__title {
    color: var(--color-text-bright);
  }

  .how-card__desc {
    color: var(--color-text-tertiary);
    text-wrap: pretty;
  }

  .how__closing {
    margin-block-start: var(--space-8);
    color: var(--color-text-secondary);
    text-align: center;
    font-size: var(--font-size-body-lg);
  }
</style>
