---
import { NAV, LINKS, SITE } from '../../site.config';
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href="#top">{SITE.name}</a>
    <nav class="site-header__nav" aria-label="Sections">
      {NAV.map(item => <a class="site-header__link" href={item.href}>{item.label}</a>)}
    </nav>
    <a class="btn btn--secondary btn--sm site-header__cta" href={LINKS.github} target="_blank" rel="noopener noreferrer">
      GitHub
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    inset-block-start: 0;
    z-index: var(--z-sticky);
    background: color-mix(in srgb, var(--color-background) 86%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-block-end: 1px solid var(--color-border-subtle);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    block-size: var(--header-height);
  }

  .site-header__brand {
    flex-shrink: 0;
    color: var(--color-text-bright);
    font-size: var(--font-size-body-lg);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-heading);
  }

  /* Mobile: a simple horizontal scroll of anchors — no JS menu. */
  .site-header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    margin-inline-start: auto;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .site-header__nav::-webkit-scrollbar {
    display: none;
  }

  .site-header__link {
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    font-size: var(--font-size-body);
    white-space: nowrap;
    transition: var(--t-base);
  }

  .site-header__link:hover {
    color: var(--color-text-primary);
    background: var(--color-surface);
  }

  .site-header__cta {
    flex-shrink: 0;
  }
</style>
