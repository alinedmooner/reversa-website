---
import { RESEARCH } from '../../site.config';
---

<section id="research" class="section">
  <div class="container">
    {/* The heading sits outside the data-reveal wrapper: its decrypt
        animation is its own reveal, and the reveal system's
        visibility:hidden would otherwise let the scramble play unseen
        (IntersectionObserver fires on geometry, not visibility). */}
    <div class="section-head">
      <p class="eyebrow">{RESEARCH.eyebrow}</p>
      <h2 class="display research__heading">
        {/* Always the real text for screen readers — the scrambled version
            is visual-only. */}
        <span class="visually-hidden">{RESEARCH.heading}</span><span data-decrypt aria-hidden="true">{RESEARCH.heading}</span>
      </h2>
    </div>
    <div class="research__copy" data-reveal>
      {RESEARCH.paragraphs.map(paragraph => <p>{paragraph}</p>)}
    </div>

    <div data-reveal>
      {/* tabindex: the horizontal scroll region must be keyboard-operable
          (Safari does not make scrollers focusable on its own). */}
      <div class="research__table-wrap" tabindex="0" role="region" aria-label={RESEARCH.table.ariaLabel}>
        <table class="table research__table">
          <caption class="visually-hidden">{RESEARCH.table.ariaLabel}</caption>
          <thead>
            <tr>
              <th scope="col"><span class="visually-hidden">Aspect</span></th>
              {RESEARCH.table.columns.map(column => <th scope="col">{column}</th>)}
            </tr>
          </thead>
          <tbody>
            {
              RESEARCH.table.rows.map(row => (
                <tr>
                  <th scope="row">{row.aspect}</th>
                  <td>{row.brazil}</td>
                  <td>{row.colombia}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="research__link">
        <a href={RESEARCH.link.href} target="_blank" rel="noopener noreferrer">{RESEARCH.link.label}</a>
      </p>
    </div>
  </div>
</section>

<script>
  // Sequential decrypt for the heading: every 40ms one more leading
  // character settles while the remainder keeps scrambling. Spaces stay
  // spaces so the line never reflows.
  const CHARSET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz!@#$%^&*()_+';

  const scramble = (text: string) =>
    text.replace(/[^ ]/g, () => CHARSET[Math.floor(Math.random() * CHARSET.length)]);

  const decrypt = (el: HTMLElement) => {
    const text = el.textContent ?? '';
    const plain = document.createElement('span');
    const scrambled = document.createElement('span');
    scrambled.className = 'research__scramble';
    el.textContent = '';
    el.append(plain, scrambled);

    let revealed = 0;
    const render = () => {
      plain.textContent = text.slice(0, revealed);
      scrambled.textContent = scramble(text.slice(revealed));
    };
    render();

    const interval = setInterval(() => {
      revealed += 1;
      if (revealed >= text.length) {
        clearInterval(interval);
        el.textContent = text;
        return;
      }
      render();
    }, 40);
  };

  // Reduced motion: never start — the server-rendered plain text stays.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            observer.unobserve(entry.target);
            decrypt(entry.target as HTMLElement);
          }
        });
      },
      { threshold: 0.1 }
    );
    document.querySelectorAll<HTMLElement>('[data-decrypt]').forEach(el => observer.observe(el));
  }
</script>

<style>
  /* Second (and last) serif display moment on the page. */
  .research__heading {
    font-size: clamp(var(--font-size-h1), 5vw, var(--font-size-display));
  }

  .research__heading :global(.research__scramble) {
    color: var(--color-text-secondary);
  }

  .research__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-inline-size: 62ch;
  }

  .research__copy p {
    font-size: var(--font-size-lead);
    line-height: var(--line-height-loose);
  }

  .research__table-wrap {
    margin-block-start: var(--space-10);
    max-inline-size: 56rem;
    overflow-x: auto;
  }

  .research__table {
    min-inline-size: 34rem;
  }

  .research__table th[scope='row'] {
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    text-align: start;
    padding: var(--space-3);
    border-block-end: 1px solid var(--color-border-subtle);
    font-size: var(--font-size-body);
  }

  .research__link {
    margin-block-start: var(--space-6);
  }

  .research__link a {
    color: var(--color-text-primary);
    text-decoration: underline;
    text-underline-offset: 0.25em;
    text-decoration-color: var(--color-border);
    transition: var(--t-base);
  }

  .research__link a:hover {
    color: var(--color-text-bright);
    text-decoration-color: var(--color-accent);
  }
</style>
